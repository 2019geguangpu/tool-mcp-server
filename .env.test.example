# 测试库 profile → Cursor MCP「db-safety-test」（MCP_PROFILE=test，含 update_test_db_rows、alter_test_table）
# 复制为 .env.test 后填写真实值（FEISHU_* / AWS_* 可与 .env 相同，从 .env 拷贝即可）
#
# cp .env.test.example .env.test

# MySQL：本地直连测试库（update_test_db_rows 要求本机 3306）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test
# 真执行 UPDATE / ALTER TABLE 前显式开启
# DB_TEST_WRITE_ENABLED=true

LOG_LEVEL=info
LOG_TO_FILE=true
AUDIT_TOOLS=true
# 多实例同时开启时，可取消注释以区分审计目录
# LOG_DIR=logs/mcp-test
# AUDIT_DIR=logs/calls/mcp-test

# MOCK_DB_TOOLS=true

AWS_REGION=us-east-1
BIZ_CORE_LOG_HOURS_DEFAULT=3

# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_USER_ACCESS_TOKEN=
