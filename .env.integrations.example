# 飞书 + CloudWatch → Cursor MCP「tool-integrations」（MCP_PROFILE=integrations）
# 不含数据库工具；DB_* 可省略。复制为 .env 或单独 .env.integrations 均可。
#
# cp .env.integrations.example .env.integrations

LOG_LEVEL=info
LOG_TO_FILE=true
AUDIT_TOOLS=true

AWS_REGION=us-east-1
# BIZ_CORE_LOG_GROUPS=/ecs/leap_server_prod_biz_core_service,/ecs/biz_core_service
BIZ_CORE_LOG_HOURS_DEFAULT=3
# MOCK_CLOUDWATCH_TOOLS=true

# 可选：GitHub API Token（提高 rate limit；不填也能用，但可能更容易触发 403/限流）
# GITHUB_TOKEN=ghp_xxx

# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_USER_ACCESS_TOKEN=
# FEISHU_NOTES_FOLDER_TOKENS=fld_xxx,fld_yyy
# FEISHU_SEARCH_PAGE_SIZE=10
# FEISHU_MAX_DOC_CHARS=48000
# FEISHU_MAX_IMAGES=30
# FEISHU_MAX_IMAGE_BYTES=5242880
# MOCK_FEISHU_TOOLS=true
