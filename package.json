{
  "name": "db-safety-mcp",
  "version": "1.0.0",
  "description": "Tool MCP Server，供 Cursor Agent 调用",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prestart": "pnpm run build",
    "prepare": "pnpm run build",
    "logs": "node dist/view-logs.js",
    "logs:last": "node dist/view-logs.js --last",
    "preinstall": "npx only-allow pnpm"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.7",
    "mysql2": "^3.14.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
