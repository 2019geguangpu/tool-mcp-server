# 线上只读 profile → Cursor MCP「db-safety-live」（MCP_PROFILE=live，无写入工具；SELECT 走 EXPLAIN 门禁）
# 复制为 .env.live 后填写真实值；经 SSM / RDS 代理时端口多为 3906
#
# cp .env.live.example .env.live

DB_HOST=127.0.0.1
DB_PORT=3906
DB_USER=root
DB_PASSWORD=
DB_NAME=your_live_database
# 线上 profile 禁止开启测试库写入
DB_TEST_WRITE_ENABLED=false

LOG_LEVEL=info
LOG_TO_FILE=true
AUDIT_TOOLS=true
# LOG_DIR=logs/mcp-live
# AUDIT_DIR=logs/calls/mcp-live

# MOCK_DB_TOOLS=true

AWS_REGION=us-east-1
# BIZ_CORE_LOG_GROUPS=/ecs/leap_server_prod_biz_core_service,/ecs/biz_core_service
BIZ_CORE_LOG_HOURS_DEFAULT=3
# MOCK_CLOUDWATCH_TOOLS=true

# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_USER_ACCESS_TOKEN=
