# MySQL 连接（复制为 .env 后填写真实值）
# 本地 AWS CLI 数据库代理（如 ssm port-forward / rds proxy）默认监听 3906
DB_HOST=127.0.0.1
DB_PORT=3906
DB_USER=root
DB_PASSWORD=
DB_NAME=test

# 日志与工具调用审计（默认写入项目 logs/ 目录）
LOG_LEVEL=info
LOG_DIR=
LOG_TO_FILE=true
AUDIT_TOOLS=true
AUDIT_DIR=

# 连通性测试：不连真实库，返回 mock DDL / EXPLAIN
# MOCK_DB_TOOLS=true

# biz-core 线上日志（CloudWatch Logs Insights，凭证与本机 aws cli 相同）
AWS_REGION=us-east-1
# BIZ_CORE_LOG_GROUPS=/ecs/leap_server_prod_biz_core_service,/ecs/biz_core_service
BIZ_CORE_LOG_HOURS_DEFAULT=3
# MOCK_CLOUDWATCH_TOOLS=true

# 飞书笔记（search 需用户 token；read 用应用 token，且应用需被加为文档协作者）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_USER_ACCESS_TOKEN=
# FEISHU_NOTES_FOLDER_TOKENS=fld_xxx,fld_yyy
# FEISHU_SEARCH_PAGE_SIZE=10
# FEISHU_MAX_DOC_CHARS=48000  # 每页字符上限；超出时用 offset_chars 分页续读
# FEISHU_MAX_IMAGES=30
# FEISHU_MAX_IMAGE_BYTES=5242880
# MOCK_FEISHU_TOOLS=true
