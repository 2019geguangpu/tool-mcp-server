# 默认示例：可用于 Cursor MCP「tool-integrations」
# 复制为 .env 后按需填写；也可使用 .env.integrations / .env.test / .env.live。
#
# cp .env.example .env

LOG_LEVEL=info
LOG_TO_FILE=true
AUDIT_TOOLS=true

# 可选：GitHub API Token（提高 rate limit；不填也能用）
# GITHUB_TOKEN=ghp_xxx

# 可选：CloudWatch Logs Insights
AWS_REGION=us-east-1
# BIZ_CORE_LOG_HOURS_DEFAULT=3

# 可选：飞书
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_USER_ACCESS_TOKEN=

